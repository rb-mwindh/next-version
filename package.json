{
  "name": "@rb-mwindh/next-version",
  "version": "1.2.4",
  "description": "CLI to discover the next version of a package based on the commit history and the conventional commit specification.",
  "author": "Markus Windhager",
  "license": "MIT",
  "private": false,
  "keywords": [
    "npm",
    "cli",
    "tool",
    "semver",
    "conventional-commits",
    "versioning",
    "release"
  ],
  "type": "module",
  "bin": {
    "next-version": "bin/cli.js"
  },
  "files": [
    "bin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rb-mwindh/next-version.git"
  },
  "homepage": "https://github.com/rb-mwindh/next-version",
  "bugs": {
    "url": "https://github.com/rb-mwindh/next-version/issues"
  },
  "scripts": {
    "start": "npx next-version",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "build": "run-s build:*",
    "build:esbuild": "tsx esbuild.config.ts",
    "build:copy-package": "cpy package*.json bin",
    "build:install-dependencies": "npm ci --omit=dev --ignore-scripts --prefix bin",
    "build:clean-package": "rimraf -g bin/package*.json"
  },
  "dependencies": {
    "@actions/artifact": "^6.1.0",
    "@actions/core": "^3.0.0",
    "commander": "^14.0.3",
    "conventional-changelog-angular": "^8.1.0",
    "conventional-changelog-atom": "^5.0.0",
    "conventional-changelog-codemirror": "^5.0.0",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "conventional-changelog-ember": "^5.0.0",
    "conventional-changelog-eslint": "^6.0.0",
    "conventional-changelog-express": "^5.0.0",
    "conventional-changelog-jquery": "^6.0.0",
    "conventional-changelog-jshint": "^5.0.0",
    "semantic-release": "^24"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.10",
    "@types/semantic-release": "^20.0.6",
    "cpy-cli": "^7.0.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-license": "^1.2.3",
    "jest": "^30.2.0",
    "npm-run-all2": "^8.0.4",
    "rimraf": "^6.1.3",
    "simple-git": "^3.31.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0"
  }
}
